#include <iostream>
#include <cmath>
using namespace std;

void solve_square_equation(float a, float b, float c, float d) {
    float x1=0, x2, x3, Diskr;
    int i, D;
    if (a == 0){
        cout << "квадратное уравнение " << endl;
        D = c * c - 4 * b * d;
        if (D < 0) {
            cout << "Корней нет1" << endl;
        } else if (D == 0) {
            cout << "Корень: " << -c / (2 * b) << endl;
        } else {
            x1 = (-c + sqrt(D)) / (2 * b);
            x2 = (-c - sqrt(D)) / (2 * b);
            cout << "Корни: " << x1 << " и " << x2 << endl;
        }
    } else if(d == 0){
        cout << "квадратное уравнение" << endl;
        D = b * b - 4 * a * c;

        if (D < 0) {
            cout << "Корней нет2" << endl;
        } else if (D == 0) {
            cout << "Корень: " << -b / (2 * a) << endl;
        } else {
            x1 = (-b + sqrt(D)) / (2 * a);
            x2 = (-b - sqrt(D)) / (2 * a);
            cout << "Корни: " << x1 << " и " << x2 << endl;
        }
    } else {
        b /= a;
        c /= a;
        d /= a;
        a = 1;
        int limit = abs(d);
        for (i = -limit; i <= limit; i++) {
            if (i != 0 && (int)d % i == 0){
                if (a*i*i*i + b*i*i + c*i + d == 0){
                    x1 = i;
                    cout << "первый корень :" << x1 << endl;
                    break;
                }
            }
        }
    }
    b = b + x1;
    c = c + b * x1 ;
    Diskr = b*b - 4 * c;
    if (Diskr < 0) {
        cout << "Корней нет" << endl;
    } else if (Diskr == 0) {
        cout << "Корень: " << -b / (2) << endl;
    } else {
        x2 = (-b + sqrt(Diskr)) / (2);
        x3 = (-b - sqrt(Diskr)) / (2);
        cout << "второй корень: " << x2 << endl;
        cout << "третий корень: " << x3 << endl;
    }
}

int main() {
    setlocale(0, "Russian");
    solve_square_equation(2, -3, -8, 12);
    return 0;
}
