#include <iostream>
#include <cmath>
using namespace std;

void solve_square_equation(float a, float b, float c) {
    float d = b * b - 4 * a * c;

    if (d < 0) {
        cout << "Корней нет" << endl;
    } else if (d == 0) {
        cout << "Корень: " << -b / (2 * a) << endl;
    } else {
        float x1 = (-b + sqrt(d)) / (2 * a);
        float x2 = (-b - sqrt(d)) / (2 * a);
        cout << "Корни: " << x1 << " и " << x2 << endl;
    }
}

int main() {
    setlocale(0, "Russian");
    solve_square_equation(5, 7, 2);
    return 0;
}
